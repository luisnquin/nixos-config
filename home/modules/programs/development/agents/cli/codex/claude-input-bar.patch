+fn render_claude_input_frame(area: Rect, buf: &mut Buffer) {
+    if area.width == 0 || area.height == 0 {
+        return;
+    }
+
+    let rail = "─".repeat(area.width as usize);
+    let rail_style = Style::default().fg(Color::DarkGray);
+    buf.set_string(area.x, area.y, &rail, rail_style);
+
+    if area.height > 1 {
+        let bottom_y = area.y.saturating_add(area.height.saturating_sub(1));
+        buf.set_string(area.x, bottom_y, &rail, rail_style);
+    }
+}
